# ============================================================================
# Drone Network Monitoring Demo – Environment Configuration
# ============================================================================
# Copy to config/aks_arc_cluster.env and fill in the USER INPUT section.
# All resource names are auto-derived from PREFIX. Override any derived name
# by uncommenting its line below.
# ============================================================================

# ===========================
#  USER INPUT (fill these in)
# ===========================

# Naming prefix – all resource names are built from this (keep short, lowercase, no spaces)
# Example: "pdxmwc26" → cluster = pdxmwc26-aks, RG = pdxmwc26-rg, etc.
PREFIX="pdx"

# Azure subscription
SUBSCRIPTION_ID=fbaf508b-cb61-4383-9cda-a42bfa0c7bc9

# Azure Local custom location (where the cluster will be placed)
CUSTOM_LOCATION_ID=/subscriptions/fbaf508b-cb61-4383-9cda-a42bfa0c7bc9/resourcegroups/portland/providers/microsoft.extendedlocation/customlocations/portland

# The Azure region that owns the resource metadata (not the on-prem location)
AZURE_METADATA_LOCATION=southcentralus

# Kubernetes version (must be v1.29+ for Foundry Local)
KUBERNETES_VERSION=1.32.6

# AAD admin group object IDs (comma-separated, applied to cluster RBAC)
AAD_ADMIN_GROUP_IDS=be0c17dc-9a37-48c5-9691-751a27a4c1b9,f5157bd2-8ce4-48b6-82df-69b9de7540a9,af0ac67a-fcb3-4c19-a950-c32f938ee163

# Networking (Azure Local logical network – control plane IP assigned from lnet directly)
VNET_RESOURCE_ID="/subscriptions/fbaf508b-cb61-4383-9cda-a42bfa0c7bc9/resourceGroups/Portland/providers/microsoft.azurestackhci/logicalnetworks/pdx-lnet-vlan32"

# Ingress preference (nginx | nginx-plus | traefik | other)
INGRESS_CONTROLLER=nginx

# Foundry Local model image (OCI URI or catalog ref – fill when ready)
FOUNDRY_MODEL_REGISTRY_URI=
FOUNDRY_IMAGE_PULL_SECRET=

# IoT Operations MQTT auth (leave blank for anonymous in-cluster)
MQTT_USERNAME=
MQTT_PASSWORD_SECRET=

# Demo tuning
DRONE_COUNT=5

# ===========================
#  AUTO-DERIVED NAMES
# ===========================
# Uncomment any line below to override the default derived name.

# --- Resource group ---
# RESOURCE_GROUP_NAME=${PREFIX}-rg
RESOURCE_GROUP_CREATE=true

# --- Key Vault (secrets, SSH keys, passwords auto-generated and stored here) ---
# KEYVAULT_NAME=${PREFIX}-kv
# Secret names stored in KV (auto-derived, override if needed):
# SSH_KEY_NAME=${PREFIX}-ssh
# MQTT_PASSWORD_NAME=${PREFIX}-mqtt-pwd
# FOUNDRY_API_KEY_NAME=${PREFIX}-foundry-key
# ADMIN_PASSWORD_NAME=${PREFIX}-admin-pwd

# --- Cluster ---
# CLUSTER_NAME=${PREFIX}-aks

# --- Hardware constraints ---
# 2x Lenovo SE350 hosts, 128 GB RAM each (256 GB total)
# 2x NVIDIA A2 GPUs (16 GB VRAM each), one per host
# Budget ~80 GB VM RAM total to leave headroom for host OS + k8s overhead

# --- Node pools (right-sized for SE350 constraints) ---
# Supported CPU SKUs: Standard_A2_v2, Standard_A4_v2, Standard_D4s_v3,
#   Standard_D8s_v3, Standard_D16s_v3, Standard_D32s_v3, Standard_K8S3_v1
#
# System pool – control plane addons, ingress, operators (2 nodes, small)
# Node pool names: lowercase alphanumeric only, 1-12 chars (no hyphens)
# SYSTEM_POOL_NAME=${PREFIX}system
SYSTEM_POOL_VM_SIZE=Standard_D4s_v3
SYSTEM_POOL_COUNT=2

# User pool – IoT Ops broker, sims, UI, aggregator (2 nodes, moderate)
# USER_POOL_NAME=${PREFIX}user
USER_POOL_VM_SIZE=Standard_D4s_v3
USER_POOL_COUNT=2

# GPU pool – Foundry Local inference (2 nodes × 1 NVIDIA A2; quantized ≤7B model)
# NC2 A2 SKUs: Standard_NC4_A2 (1 GPU, 4 vCPU, 16GB) | Standard_NC8_A2 (1 GPU, 8 vCPU, 16GB)
# GPU_POOL_NAME=${PREFIX}gpu
GPU_POOL_VM_SIZE=Standard_NC4_A2
GPU_POOL_COUNT=1
GPU_PER_NODE=1
GPU_SKU=nvidia-a2
GPU_NODE_TAINT=

# --- Namespaces / extension names ---
# IOT_OPS_EXTENSION_NAME=${PREFIX}-iotops
# IOT_OPS_NAMESPACE=${PREFIX}-iot
# MQTT_BROKER_SERVICE=${PREFIX}-mqtt
# FOUNDRY_OPERATOR_NAMESPACE=${PREFIX}-foundry-op
# FOUNDRY_MODEL_NAMESPACE=${PREFIX}-foundry-mdl

# --- MQTT topics ---
# TELEMETRY_TOPIC=drone/telemetry/#
# COMMAND_TOPIC=drone/command

# ============================================================================
CONFIG_VERSION=2