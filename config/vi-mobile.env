# ============================================================================
# Video Indexer Cluster — Mobile Azure Local Stamp (AD-less)
# ============================================================================
# AKS Arc cluster for Arc Video Indexer + Foundry Local + CV Inference
# Deployed on the Mobile Azure Local stamp (eastus, AD-less design)
#
# DNS zone: acx.mobile (not adaptivecloudlab.com)
# ============================================================================

# ===========================
#  USER INPUT (fill these in)
# ===========================

PREFIX="vi"

# Azure subscription
SUBSCRIPTION_ID=fbaf508b-cb61-4383-9cda-a42bfa0c7bc9

# Azure Local custom location (Mobile stamp)
CUSTOM_LOCATION_ID=/subscriptions/fbaf508b-cb61-4383-9cda-a42bfa0c7bc9/resourceGroups/ACX-Mobile-AZL/providers/Microsoft.ExtendedLocation/customLocations/Mobile

# The Azure region that owns the resource metadata
AZURE_METADATA_LOCATION=eastus

# Kubernetes version (must be v1.29+ for Foundry Local and Video Indexer)
KUBERNETES_VERSION=1.32.9

# AAD admin group object IDs (comma-separated)
AAD_ADMIN_GROUP_IDS=094db372-f9b2-4477-937c-869b8cf2bb8a

# Networking (Azure Local logical network on Mobile stamp — VLAN50, 172.25.10.0/24)
VNET_RESOURCE_ID="/subscriptions/fbaf508b-cb61-4383-9cda-a42bfa0c7bc9/resourceGroups/ACX-Mobile-AZL/providers/microsoft.azurestackhci/logicalNetworks/mobile-Lnet-vlan50"

# Ingress
INGRESS_CONTROLLER=nginx

# Foundry Local model image
FOUNDRY_MODEL_REGISTRY_URI=
FOUNDRY_IMAGE_PULL_SECRET=

# Demo tuning
DRONE_COUNT=5

# MetalLB VIP range — subnet 172.25.10.0/24, pool .30–.240, existing cluster uses lower range.
# Using upper range to avoid conflicts with mobile-mwc-26 cluster.
METALLB_IP_RANGE=172.25.10.200-172.25.10.210

# ===========================
#  AUTO-DERIVED NAMES
# ===========================

RESOURCE_GROUP_NAME=acx-mobile-azl
RESOURCE_GROUP_CREATE=false

# Key Vault (globally unique — "vi-kv" is taken; use longer name)
KEYVAULT_NAME=vi-mobile-kv

# --- Cluster ---
# CLUSTER_NAME=${PREFIX}-aks

# --- Node pools ---
SYSTEM_POOL_VM_SIZE=Standard_D4s_v3
SYSTEM_POOL_COUNT=2

USER_POOL_VM_SIZE=Standard_D4s_v3
USER_POOL_COUNT=2

# GPU pool — NVIDIA A2 for Foundry Local + YOLO inference + Video Indexer
GPU_POOL_VM_SIZE=Standard_NC4_A2
GPU_POOL_COUNT=1
GPU_PER_NODE=1
GPU_SKU=nvidia-a2
GPU_NODE_TAINT=

# ===========================
#  VIDEO INDEXER SETTINGS
# ===========================

# Arc Video Indexer extension name
VI_EXTENSION_NAME=videoindexer

# Video Indexer account name
VI_ACCOUNT_NAME=vi-mobile-account

# Storage class for Video Indexer (must be RWX — Longhorn)
VI_STORAGE_CLASS=longhorn

# ===========================
#  CV INFERENCE SETTINGS
# ===========================

# Pre-trained YOLO model (ONNX format, pulled from ACR at deploy time)
CV_MODEL_IMAGE=drone-demo/cv-models:yolov8s-antenna-v1

# Inference confidence threshold
CV_CONFIDENCE_THRESHOLD=0.5

# ===========================
#  DASHBOARD SETTINGS
# ===========================

# Video analysis dashboard
VIDEO_DASHBOARD_PORT=5000
VIDEO_DASHBOARD_HOSTNAME=video.acx.mobile

# Monitoring
GRAFANA_HOSTNAME=grafana-vi.acx.mobile

# ===========================
#  EDGE AI (Foundry Local)
# ===========================

EDGE_AI_ENDPOINT=https://phi-4-deployment.vi-foundry-mdl.svc:5000
EDGE_AI_MODEL=Phi-4-mini-instruct

# ============================================================================
CONFIG_VERSION=2
