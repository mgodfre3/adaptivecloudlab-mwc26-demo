# ============================================================================
# Deployment Configuration — Per-environment settings
# ============================================================================
# Copy this file to config/deployment.env and fill in YOUR values.
# This file is gitignored — your real values will never be committed.
#
# Used by:
#   - scripts/04-deploy-drone-demo.ps1 (builds, pushes, deploys)
#   - k8s/drone-demo.yaml.template    (rendered to k8s/drone-demo.yaml)
# ============================================================================

# ── Container Registry ───────────────────────────────────────────────────────
# ACR login server (full FQDN, e.g. myacr.azurecr.io)
ACR_LOGIN_SERVER=<YOUR_ACR_LOGIN_SERVER>

# ── Cluster Details ──────────────────────────────────────────────────────────
# Node selector label for user node pool (find with: kubectl get nodes --show-labels)
# Format: msft.microsoft/nodepool-name=<value>
NODE_POOL_LABEL=<YOUR_NODE_POOL_LABEL>

# ── IoT Hub ──────────────────────────────────────────────────────────────────
IOT_HUB_NAME=<YOUR_IOT_HUB_NAME>

# ── Ingress / DNS ────────────────────────────────────────────────────────────
# The FQDN visitors will use to reach the dashboard
# TLS cert base domain is auto-derived (e.g. mwc.example.com → example.com)
INGRESS_HOSTNAME=<YOUR_HOSTNAME>

# ── Flask ────────────────────────────────────────────────────────────────────
# Random secret used to sign session cookies (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=<GENERATE_A_RANDOM_SECRET>

# ── Edge AI ──────────────────────────────────────────────────────────────────
# In-cluster Foundry Local endpoint (no port-forward needed when running on cluster)
EDGE_AI_ENDPOINT=https://phi-3-deployment.foundry-local.svc:5000
EDGE_AI_MODEL=Phi-3-mini-4k-instruct-cuda-gpu:1

# -- Data Sovereignty ----------------------------------------------------------
DATA_MODE=cloud
MQTT_BROKER_HOST=aio-broker-insecure.azure-iot-operations.svc
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=drone/telemetry
IOT_HUB_HOSTNAME=<prefix>-iothub.azure-devices.net
