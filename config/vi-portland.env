# ============================================================================
# Video Indexer Cluster — Portland Azure Local Stamp (Backup Demo Environment)
# ============================================================================
# AKS Arc cluster for Arc Video Indexer + Foundry Local + CV Inference
# Deployed on the Portland Azure Local stamp (southcentralus)
#
# DNS zone: adaptivecloudlab.com
# This is the second (backup) deployment of the Video Indexer demo.
# The Mobile stamp is unavailable (in transit to the conference).
# ============================================================================

# ===========================
#  USER INPUT (fill these in)
# ===========================

PREFIX="pdx"

# Azure subscription
SUBSCRIPTION_ID=fbaf508b-cb61-4383-9cda-a42bfa0c7bc9

# Azure Local custom location (Portland stamp)
CUSTOM_LOCATION_ID=/subscriptions/fbaf508b-cb61-4383-9cda-a42bfa0c7bc9/resourceGroups/pdx-rg/providers/Microsoft.ExtendedLocation/customLocations/Portland

# The Azure region that owns the resource metadata
AZURE_METADATA_LOCATION=southcentralus

# Kubernetes version (must be v1.29+ for Foundry Local and Video Indexer)
KUBERNETES_VERSION=1.32.9

# AAD admin group object IDs (comma-separated)
AAD_ADMIN_GROUP_IDS=094db372-f9b2-4477-937c-869b8cf2bb8a

# Networking (Azure Local logical network on Portland stamp)
VNET_RESOURCE_ID="/subscriptions/fbaf508b-cb61-4383-9cda-a42bfa0c7bc9/resourceGroups/pdx-rg/providers/microsoft.azurestackhci/logicalNetworks/pdx-lnet"

# Ingress
INGRESS_CONTROLLER=nginx

# Foundry Local model image
FOUNDRY_MODEL_REGISTRY_URI=
FOUNDRY_IMAGE_PULL_SECRET=

# Demo tuning
DRONE_COUNT=5

# MetalLB VIP range — subnet 172.21.229.0/26 (Portland stamp).
# Lower range used by the existing drone-demo cluster; upper range reserved for VI services.
METALLB_IP_RANGE=172.21.229.180-172.21.229.185

# ===========================
#  AUTO-DERIVED NAMES
# ===========================

RESOURCE_GROUP_NAME=pdx-rg
RESOURCE_GROUP_CREATE=false

# Key Vault
KEYVAULT_NAME=pdx-kv

# Cluster — second cluster on Portland stamp for Video Indexer workloads
CLUSTER_NAME=pdx-vi-aks

# --- Node pools ---
SYSTEM_POOL_VM_SIZE=Standard_D4s_v3
SYSTEM_POOL_COUNT=2

USER_POOL_VM_SIZE=Standard_D4s_v3
USER_POOL_COUNT=2

# GPU pool — NVIDIA A2 for Foundry Local + YOLO inference + Video Indexer
GPU_POOL_VM_SIZE=Standard_NC4_A2
GPU_POOL_COUNT=1
GPU_PER_NODE=1
GPU_SKU=nvidia-a2
GPU_NODE_TAINT=

# ===========================
#  VIDEO INDEXER SETTINGS
# ===========================

# Arc Video Indexer extension name
VI_EXTENSION_NAME=videoindexer

# Video Indexer account name
VI_ACCOUNT_NAME=vi-portland-account

# Storage class for Video Indexer (must be RWX — Longhorn)
VI_STORAGE_CLASS=longhorn

# ===========================
#  CV INFERENCE SETTINGS
# ===========================

# Pre-trained YOLO model (ONNX format, pulled from ACR at deploy time)
CV_MODEL_IMAGE=drone-demo/cv-models:yolov8s-antenna-v1

# Inference confidence threshold
CV_CONFIDENCE_THRESHOLD=0.5

# ===========================
#  DASHBOARD SETTINGS
# ===========================

# Video analysis dashboard
VIDEO_DASHBOARD_PORT=5000
VIDEO_DASHBOARD_HOSTNAME=video.adaptivecloudlab.com

# Monitoring
GRAFANA_HOSTNAME=grafana-vi.adaptivecloudlab.com

# ===========================
#  EDGE AI (Foundry Local)
# ===========================

EDGE_AI_ENDPOINT=https://phi-4-deployment.vi-foundry-local.svc:5000
EDGE_AI_MODEL=Phi-4-mini-instruct-cuda-gpu:5

# ============================================================================
CONFIG_VERSION=2
