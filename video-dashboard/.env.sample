# ── Video Analysis Dashboard Configuration ─────────────────────────────────
# Copy this to .env and fill in values

# Dashboard port
DASHBOARD_PORT=5000

# Flask secret key for session signing (generate with: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=

# ── Edge AI (Foundry Local on AKS Arc GPU node) ──────────────────────────
# Foundry Local endpoint (ClusterIP service in foundry-local namespace)
# When running locally use kubectl port-forward:
#   kubectl port-forward svc/phi-4-deployment -n foundry-local 8443:5000
EDGE_AI_ENDPOINT=https://localhost:8443

# Model name from Foundry Local catalog (use /v1/models to list)
EDGE_AI_MODEL=Phi-4-mini-instruct

# Foundry Local API key (from phi-4-deployment-api-keys secret)
# Retrieve with:
#   kubectl get secret phi-4-deployment-api-keys -n foundry-local \
#     -o jsonpath='{.data.api-key}' | base64 -d
EDGE_AI_API_KEY=

# ── Arc Video Indexer ─────────────────────────────────────────────────────
# Video Indexer API endpoint on the AKS Arc cluster
VI_ENDPOINT=http://video-indexer.video-indexer.svc:5000

# ── Storage ───────────────────────────────────────────────────────────────
# Directory for uploaded videos and processing artifacts
DATA_DIR=/data
