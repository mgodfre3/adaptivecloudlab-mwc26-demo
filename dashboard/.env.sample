# Dashboard configuration
# Copy this to .env and fill in values

# Set to "true" to run with synthetic demo data (no IoT Hub needed)
DEMO_MODE=true

# IoT Hub Event Hub-compatible connection string (leave empty for demo mode)
# Retrieve with:
#   az iot hub connection-string show --hub-name <hub> --default-eventhub --query connectionString -o tsv
EVENTHUB_CONNECTION_STRING=

# Event Hub consumer group
EVENTHUB_CONSUMER_GROUP=drone-telemetry

# Number of drones (demo mode)
DRONE_COUNT=5

# Dashboard port
DASHBOARD_PORT=5000

# ── Edge AI (Foundry Local on GPU node) ──────────────────────────────
# Set to "true" to call the Foundry Local API for AI insights; "false" uses rule-based demo insights
EDGE_AI_ENABLED=true

# Foundry Local endpoint (ClusterIP service in foundry-local namespace)
# When running locally use kubectl port-forward: kubectl port-forward svc/phi-4-deployment -n foundry-local 8443:5000
EDGE_AI_ENDPOINT=https://localhost:8443

# Model name from Foundry Local catalog (use /v1/models to list)
EDGE_AI_MODEL=Phi-4-mini-instruct

# Foundry Local API key (from phi-4-deployment-api-keys secret in foundry-local namespace)
# Retrieve with: kubectl get secret phi-4-deployment-api-keys -n foundry-local -o jsonpath='{.data.api-key}' | base64 -d
EDGE_AI_API_KEY=

# Seconds between AI analysis cycles
EDGE_AI_INTERVAL=15

# -- Data Sovereignty ----------------------------------------------------------
DATA_MODE=cloud
MQTT_BROKER_HOST=aio-broker-insecure.azure-iot-operations.svc
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=drone/telemetry

# ── Map / Location (change per demo environment) ──────────────────────────────
# Display name shown in logs
MAP_LOCATION_NAME=Denver, CO
# Map center coordinates (Leaflet map initial view)
MAP_CENTER_LAT=39.7484
MAP_CENTER_LON=-104.9951
# Drone home/base pad coordinates
MAP_BASE_LAT=39.7437
MAP_BASE_LON=-104.9916
# Initial zoom level (13 works well for a city-wide drone patrol view)
MAP_ZOOM=13
